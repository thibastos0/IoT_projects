#include <Arduino.h>
#include <WiFi.h>
#include <WiFiClient.h>
#include <WebServer.h>
#include <uri/UriBraces.h>

//const char *ssid = "Wokwi-GUEST";
//const char *password = "";
//const char *ssid = "Sala Maker";
//const char *password = "Maker@fatec";
#define ssid "Wokwi-GUEST"
#define password ""
#define channel 6

WebServer server(80);

const int LED_PIN_FAROL = 13;
bool farolStatus = false;

// Página HTML estilizada
void sendHtml() {
  String Htmlresponse = R"(
  <!DOCTYPE html><html><head>
    <title>ESP32 Web Control</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    </head><body>
      <style>body{font-family:sans-serif; text-align:center; padding:20px;}
        .btn{background:#2ecc71; color:white; padding:15px 25px; border:none; border-radius:5px; font-size:18px; cursor:pointer; text-decoration:none;}
      .btn-off{background:#e74c3c;}
      </style>
    <h1>ESP32 Wokwi Server</h1>
      <p>Status do LED: <strong> farolStatus</strong></p>
      <p><a href="/on"><button class="btn">LIGAR</button></a></p>
      <p><a href="/off"><button class="btn btn-off">DESLIGAR</button></a></p>
    </body>
  </html>
)";
  Htmlresponse.replace("farolStatus", farolStatus ? "LIGADO" : "DESLIGADO");
  server.send(200, "text/html", Htmlresponse);
}

void setup() {
  pinMode(LED_PIN_FAROL, OUTPUT);
  Serial.begin(115200);
  delay(1000);

  Serial.println("\n\n=== ESP32 Web Server ===");
  Serial.print("Conectando ao WiFi: ");
  Serial.println(ssid);
  
  WiFi.begin(ssid, password);
  
  // Timeout de 20 segundos para conectar
  int tentativas = 40;
  while (WiFi.status() != WL_CONNECTED && tentativas > 0) {
    delay(500);
    Serial.print(".");
    tentativas--;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nConectado ao WiFi!");
    Serial.print("IP local: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("\nNão conectou ao WiFi, mas iniciando servidor mesmo assim...");
    Serial.println("IP esperado: 10.0.0.1");
  }

  // Configura as rotas do servidor
  server.on("/", sendHtml);
  
  server.on(UriBraces("/{}"), []() {
    String param = server.pathArg(0);
    
    String logMsg = "Recebido comando: " + param;
    Serial.println(logMsg);

    if (param == "on") {
      farolStatus = true;
      digitalWrite(LED_PIN_FAROL, HIGH);
    } else if (param == "off") {
      farolStatus = false;
      digitalWrite(LED_PIN_FAROL, LOW);
    }
    sendHtml();
  });

  server.begin();
  Serial.println("Servidor HTTP iniciado");
  Serial.println("Acesse: http://localhost:8180");
}

void loop() {
  server.handleClient();
  delay(2);
}